## Supabase (required)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_JWT"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_JWT"

## Server-only (required for CMS writes)
SUPABASE_SERVICE_ROLE="YOUR_SUPABASE_SERVICE_ROLE_JWT"

## CMS Admin (required to access /cms)
## Comma-separated allowlist. These users must already exist in Supabase Auth.
CMS_ADMIN_EMAILS="admin@yourdomain.com"

## Optional, used for magic link and password reset redirect URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
